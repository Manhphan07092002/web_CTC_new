# MongoDB Configuration
MONGO_URI=mongodb://localhost:27017/ctc_web_new

# Server Configuration
PORT=4000
NODE_ENV=development

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# File Upload Configuration
MAX_FILE_SIZE=5242880
UPLOAD_DIR=./uploads

# Email Configuration (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=your-email@gmail.com
CONTACT_RECIPIENT=contac@ctcdn.vn

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Admin Configuration
ADMIN_EMAIL=admin@tranle.com
ADMIN_PASSWORD=TranLe@2024

# API Configuration
API_BASE_URL=http://localhost:4000/api

# Security
CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100

# Social Media (Optional)
FACEBOOK_URL=https://facebook.com/tranle
INSTAGRAM_URL=https://instagram.com/tranle
YOUTUBE_URL=https://youtube.com/@tranle

# Google Analytics (Optional)
GA_TRACKING_ID=UA-XXXXXXXXX-X

# Maintenance Mode
MAINTENANCE_MODE=false
