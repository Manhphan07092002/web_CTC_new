{
  "name": "tran-le-electricity---solar-energy",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently --kill-others-on-fail --prefix-colors \"cyan,yellow\" --names \"[CLIENT],[SERVER]\" \"vite\" \"tsx watch server/index.ts\"",
    "dev:client": "vite",
    "dev:server": "tsx watch server/index.ts",
    "build": "tsc && vite build",
    "build:analyze": "tsc && vite build --mode production",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "server": "node --import tsx server/index.ts",
    "setup": "node scripts/setup-database.js",
    "seed-admin": "node --loader ts-node/esm --experimental-specifier-resolution=node scripts/seed-admin.js",
    "reset-password": "node --loader ts-node/esm --experimental-specifier-resolution=node scripts/reset-password.js",
    "migrate-settings": "node --loader ts-node/esm --experimental-specifier-resolution=node server/migrate-settings.ts",
    "seed-analytics": "node scripts/seed-analytics.js",
    "capture-metrics": "node scripts/capture-metrics.js",
    "export-data": "node scripts/export-all-data.js",
    "import-data": "node scripts/import-all-data.js",
    "setup-first-time": "node scripts/setup-first-time.js",
    "setup-with-data": "node scripts/setup-with-data.js"
  },
  "dependencies": {
    "@google/genai": "^1.29.1",
    "@types/bcrypt": "^6.0.0",
    "@types/node-cache": "^4.1.3",
    "@types/nodemailer": "^7.0.3",
    "@types/validator": "^13.15.10",
    "@vitalets/google-translate-api": "^9.2.1",
    "adm-zip": "^0.6.0",
    "baseline-browser-mapping": "^2.10.43",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-robots-txt": "^1.0.0",
    "express-validator": "^7.3.1",
    "i18next": "^25.7.1",
    "i18next-fs-backend": "^2.6.1",
    "i18next-http-middleware": "^3.8.2",
    "lucide-react": "^0.553.0",
    "mongodb": "^7.0.0",
    "mongoose": "^8.19.4",
    "msnodesqlv8": "^5.2.2",
    "mssql": "^12.7.0",
    "multer": "^1.4.5-lts.1",
    "node-cache": "^5.1.2",
    "node-fetch": "^3.3.2",
    "nodemailer": "^7.0.10",
    "prerender-node": "^3.8.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^2.0.5",
    "react-router-dom": "^7.9.6",
    "recharts": "^3.4.1",
    "sitemap": "^9.0.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^10.0.3",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.20.6",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
